# --- Как хранить ключи ---
# 1) Скопируйте этот файл: cp .env.example .env
# 2) Заполните значения только в .env (файл в .gitignore — не попадает в git).
# 3) В CI/CD используйте секреты окружения платформы, а не файл в репозитории.
#
# --- Яндекс.Карты API ---
# Ключ сейчас отдаётся браузеру через GET /api/config (нужен для загрузки JS API).
# В кабинете разработчика Яндекса ограничьте ключ по HTTP Referrer (ваш домен / localhost),
# иначе при утечке ключом могут воспользоваться с чужого сайта.

# Порт HTTP. Локально: 3000, 3011 и т.д. В Railway/Render не указывайте — используется process.env.PORT.
PORT=3011

# PostgreSQL (Prisma). Локально через Docker — см. docker-compose.yml:
#   docker compose up -d
#   npm run db:migrate
#   npm run db:check
# По умолчанию контейнер слушает на хосте :5433 (если 5432 занят другим Postgres).
# Нужен именно 5432 — в docker-compose.yml смените порты на "5432:5432" и URL ниже.
DATABASE_URL=postgresql://postgres:password@localhost:5433/postgres
#
# Облако (Neon и т.п.): postgresql://user:pass@host/neondb?sslmode=require
#
# Миграции: npm run db:migrate  (или npx prisma migrate dev)

# Секрет подписи JWT (не короче 16 символов)
JWT_SECRET=замените_на_длинную_случайную_строку
# JWT_EXPIRES_IN=30d

# Ключ JavaScript API Яндекс.Карт (ограничьте по referrer)
YANDEX_MAPS_API_KEY=

# URL Google Sheets больше не задаётся здесь — каждый пользователь сохраняет свою таблицу после входа.

# Цвета статусов: lib/map-statuses.js (STATUS_COLORS)
